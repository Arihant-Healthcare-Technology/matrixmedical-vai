# UKG Pro to Motus Integration - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# UKG Pro API Configuration
# ============================================
UKG_BASE_URL=https://service4.ultipro.com
UKG_USERNAME=your-ukg-username
UKG_PASSWORD=your-ukg-password
# Optional: Pre-encoded base64 of "username:password" (overrides USERNAME/PASSWORD)
# UKG_BASIC_B64=
UKG_CUSTOMER_API_KEY=your-ukg-customer-api-key

# Company ID for UKG queries
COMPANY_ID=J9A6Y

# ============================================
# Motus API Configuration
# ============================================
MOTUS_API_BASE=https://api.motus.com/v1
MOTUS_JWT=your-motus-jwt-token

# Token generation credentials
MOTUS_TOKEN_URL=https://token.motus.com/tokenservice/token/api
MOTUS_LOGIN_ID=your-motus-login-id
MOTUS_PASSWORD=your-motus-password

# Token cache settings
# MOTUS_TOKEN_CACHE=.motus_token.json
# MOTUS_TOKEN_REFRESH_SAFETY=60
# MOTUS_DEFAULT_TTL_SECONDS=3300

# ============================================
# Program Configuration
# ============================================
# Motus Program ID (default: CPM = 21233, FAVR = 21232)
MOTUS_PROGRAM_ID=21233

# ============================================
# Batch Processing Configuration
# ============================================
# Number of parallel workers
WORKERS=12

# Rate limiting (calls per minute)
# RATE_LIMIT_CALLS_PER_MINUTE=60

# Maximum retry attempts
MAX_RETRIES=2

# Filter by US states (comma-separated, e.g., FL,MS,NJ)
# STATES=

# Output directory for batch files
# OUT_DIR=data/batch

# ============================================
# Notifications (Optional)
# ============================================
# Email notifications for batch completion
# NOTIFICATION_ENABLED=0
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=alerts@example.com
# SMTP_PASSWORD=your-smtp-password
# NOTIFICATION_FROM=alerts@matrixmedical.com
# NOTIFICATION_TO=admin@matrixmedical.com

# ============================================
# Secrets Provider (Optional)
# ============================================
# Options: env (default), aws, vault
# SECRETS_PROVIDER=env

# AWS Secrets Manager (if SECRETS_PROVIDER=aws)
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=matrix/ukg-motus/prod

# HashiCorp Vault (if SECRETS_PROVIDER=vault)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your-vault-token
# VAULT_PATH=secret/matrix/ukg-motus

# ============================================
# Debug & Development
# ============================================
# Enable debug logging
DEBUG=0

# Redact PII in logs
REDACT_PII=1

# Dry-run mode (validate without API calls)
# DRY_RUN=0

# Save local JSON files
# SAVE_LOCAL=0

# Probe mode (GET to check insert/update action)
# PROBE=0
