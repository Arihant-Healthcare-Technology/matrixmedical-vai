# =============================================================================
# Development Environment - BILL.com Integration
# =============================================================================
# This file contains development/sandbox configuration.
# Copy to .env for local development or specify via --env-file flag.
# =============================================================================

ENVIRONMENT=development

# -----------------------------------------------------------------------------
# UKG Pro Configuration (Development/Sandbox)
# -----------------------------------------------------------------------------
UKG_BASE_URL=https://service4.ultipro.com
# REQUIRED: UKG credentials
UKG_USERNAME=
UKG_PASSWORD=
# REQUIRED: UKG Customer API Key
UKG_CUSTOMER_API_KEY=
# OPTIONAL: Pre-encoded Basic Auth (alternative to username/password)
UKG_BASIC_B64=
# OPTIONAL: Default company ID
UKG_COMPANY_ID=
UKG_TIMEOUT=45

# -----------------------------------------------------------------------------
# BILL.com Spend & Expense Configuration (Sandbox)
# -----------------------------------------------------------------------------
BILL_API_BASE=https://gateway.stage.bill.com/connect/v3/spend
# REQUIRED for S&E module
BILL_SE_API_TOKEN=
BILL_DEFAULT_ROLE=MEMBER

# -----------------------------------------------------------------------------
# BILL.com Accounts Payable Configuration (Sandbox)
# -----------------------------------------------------------------------------
BILL_AP_API_BASE=https://gateway.stage.bill.com/connect/v3
# REQUIRED for AP module
BILL_AP_API_TOKEN=

# -----------------------------------------------------------------------------
# Shared BILL.com Settings
# -----------------------------------------------------------------------------
# Shared API Token (fallback if module-specific tokens not set)
BILL_API_TOKEN=
# Organization ID
BILL_ORG_ID=
BILL_PRODUCTION=false
BILL_RATE_LIMIT=60
BILL_MAX_RETRIES=3
BILL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Batch Processing (Development - Limited)
# -----------------------------------------------------------------------------
BATCH_WORKERS=4
BATCH_LIMIT=10
SAVE_LOCAL=true

# -----------------------------------------------------------------------------
# Scraping/Browser Automation (Development)
# -----------------------------------------------------------------------------
SCRAPING_HEADLESS=false
SCRAPING_TIMEOUT=60000
SCRAPING_SLOW_MO=100
SCRAPING_LOGIN_EMAIL=
SCRAPING_LOGIN_PASSWORD=
SCRAPING_COMPANY_NAME=
SCRAPING_VIEWPORT_WIDTH=1920
SCRAPING_VIEWPORT_HEIGHT=1080
SCRAPING_OUTPUT_DIR=output

# -----------------------------------------------------------------------------
# Logging (Development - Verbose)
# -----------------------------------------------------------------------------
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_INCLUDE_CORRELATION_ID=true
LOG_REDACT_PII=false

# -----------------------------------------------------------------------------
# Notifications (Disabled in Development)
# -----------------------------------------------------------------------------
NOTIFY_ENABLED=false
NOTIFY_PROVIDER=smtp
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_RECIPIENTS=
NOTIFY_SENDER_EMAIL=noreply@integration.local
NOTIFY_SENDER_NAME=UKG Integration Suite (Dev)

# -----------------------------------------------------------------------------
# Secrets Provider (Development - Use Environment Variables)
# -----------------------------------------------------------------------------
SECRETS_PROVIDER=env
