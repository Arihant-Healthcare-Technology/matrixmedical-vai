# =============================================================================
# Production Environment - BILL.com Integration
# =============================================================================
# This file contains production configuration.
# Credentials should be injected via secrets manager or CI/CD pipeline.
# DO NOT commit actual secrets to version control.
# =============================================================================

ENVIRONMENT=production

# -----------------------------------------------------------------------------
# UKG Pro Configuration (Production)
# -----------------------------------------------------------------------------
UKG_BASE_URL=https://service4.ultipro.com
# REQUIRED: UKG credentials
UKG_USERNAME=${UKG_USERNAME}
UKG_PASSWORD=${UKG_PASSWORD}
# REQUIRED: UKG Customer API Key
UKG_CUSTOMER_API_KEY=${UKG_CUSTOMER_API_KEY}
# OPTIONAL: Pre-encoded Basic Auth (alternative to username/password)
UKG_BASIC_B64=${UKG_BASIC_B64}
# OPTIONAL: Default company ID
UKG_COMPANY_ID=${UKG_COMPANY_ID}
UKG_TIMEOUT=60

# -----------------------------------------------------------------------------
# BILL.com Spend & Expense Configuration (Production)
# -----------------------------------------------------------------------------
BILL_API_BASE=https://gateway.bill.com/connect/v3/spend
# REQUIRED for S&E module
BILL_SE_API_TOKEN=${BILL_SE_API_TOKEN}
BILL_DEFAULT_ROLE=MEMBER

# -----------------------------------------------------------------------------
# BILL.com Accounts Payable Configuration (Production)
# -----------------------------------------------------------------------------
BILL_AP_API_BASE=https://gateway.bill.com/connect/v3
# REQUIRED for AP module
BILL_AP_API_TOKEN=${BILL_AP_API_TOKEN}

# -----------------------------------------------------------------------------
# Shared BILL.com Settings
# -----------------------------------------------------------------------------
# Shared API Token (fallback if module-specific tokens not set)
BILL_API_TOKEN=${BILL_API_TOKEN}
# Organization ID
BILL_ORG_ID=${BILL_ORG_ID}
BILL_PRODUCTION=true
BILL_RATE_LIMIT=60
BILL_MAX_RETRIES=5
BILL_TIMEOUT=60

# -----------------------------------------------------------------------------
# Batch Processing (Production - Full Capacity)
# -----------------------------------------------------------------------------
BATCH_WORKERS=12
BATCH_LIMIT=0
SAVE_LOCAL=false

# -----------------------------------------------------------------------------
# Scraping/Browser Automation (Production)
# -----------------------------------------------------------------------------
SCRAPING_HEADLESS=true
SCRAPING_TIMEOUT=120000
SCRAPING_SLOW_MO=0
SCRAPING_LOGIN_EMAIL=${SCRAPING_LOGIN_EMAIL}
SCRAPING_LOGIN_PASSWORD=${SCRAPING_LOGIN_PASSWORD}
SCRAPING_COMPANY_NAME=${SCRAPING_COMPANY_NAME}
SCRAPING_VIEWPORT_WIDTH=1920
SCRAPING_VIEWPORT_HEIGHT=1080
SCRAPING_OUTPUT_DIR=output

# -----------------------------------------------------------------------------
# Logging (Production - Structured JSON)
# -----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_INCLUDE_CORRELATION_ID=true
LOG_REDACT_PII=true

# -----------------------------------------------------------------------------
# Notifications (Production - Enabled)
# -----------------------------------------------------------------------------
NOTIFY_ENABLED=true
NOTIFY_PROVIDER=ses
NOTIFY_SES_REGION=us-east-1
NOTIFY_RECIPIENTS=${NOTIFY_RECIPIENTS}
NOTIFY_SENDER_EMAIL=${NOTIFY_SENDER_EMAIL}
NOTIFY_SENDER_NAME=UKG Integration Suite

# -----------------------------------------------------------------------------
# Secrets Provider (Production - AWS Secrets Manager)
# -----------------------------------------------------------------------------
SECRETS_PROVIDER=aws
AWS_REGION=us-east-1
AWS_SECRET_NAME=matrix/ukg-bill/prod
