# ==============================================================================
# UKG to BILL.com Integration - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env files with real credentials to version control.
# ==============================================================================

ENVIRONMENT=development

# ------------------------------------------------------------------------------
# UKG Pro API Configuration
# ------------------------------------------------------------------------------
# Base URL for UKG Pro API
UKG_BASE_URL=https://service4.ultipro.com

# REQUIRED: UKG Pro credentials
UKG_USERNAME=your-ukg-username
UKG_PASSWORD=your-ukg-password

# REQUIRED: UKG Customer API Key
UKG_CUSTOMER_API_KEY=your-ukg-customer-api-key

# OPTIONAL: Pre-encoded Basic Auth header (base64 of username:password)
# If set, used instead of UKG_USERNAME/UKG_PASSWORD
# UKG_BASIC_B64=

# OPTIONAL: Default UKG company ID (if not specified in CLI)
# UKG_COMPANY_ID=

UKG_TIMEOUT=30

# Employee Change Filtering
# Only process employees changed within this many days (optional, no filter if not set)
# Filters based on UKG's dateTimeChanged attribute
# Example: UKG_DAYS_TO_PROCESS=2 will only sync employees changed in the last 2 days
# UKG_DAYS_TO_PROCESS=

# ------------------------------------------------------------------------------
# BILL.com Spend & Expense (S&E) Configuration
# ------------------------------------------------------------------------------
# S&E API Base URL
# Production: https://gateway.bill.com/connect/v3/spend
# Staging:    https://gateway.stage.bill.com/connect/v3/spend
BILL_API_BASE=https://gateway.stage.bill.com/connect/v3/spend

# REQUIRED for S&E module: BILL.com S&E API Token
BILL_SE_API_TOKEN=your-bill-se-api-token

# Default role for new users
BILL_DEFAULT_ROLE=MEMBER

# ------------------------------------------------------------------------------
# BILL.com Accounts Payable (AP) Configuration
# ------------------------------------------------------------------------------
# AP API Base URL
# Production: https://gateway.bill.com/connect/v3
# Staging:    https://gateway.stage.bill.com/connect/v3
BILL_AP_API_BASE=https://gateway.stage.bill.com/connect/v3

# REQUIRED for AP module: BILL.com AP API Token
BILL_AP_API_TOKEN=your-bill-ap-api-token

# Optional: Default funding account for AP payments
# BILL_DEFAULT_FUNDING_ACCOUNT=your-funding-account-id

# ------------------------------------------------------------------------------
# Shared BILL.com Settings
# ------------------------------------------------------------------------------
# Shared API Token (fallback if module-specific tokens not set)
BILL_API_TOKEN=your-bill-api-token

# BILL.com Organization ID
BILL_ORG_ID=your-bill-org-id

# Production flag
BILL_PRODUCTION=false

# Rate Limiting (BILL.com limit is 60 calls/minute)
BILL_RATE_LIMIT=60
BILL_MAX_RETRIES=3
BILL_TIMEOUT=30

# ------------------------------------------------------------------------------
# BILL.com Browser Automation (for UI-only features)
# ------------------------------------------------------------------------------
# Required for CSV import and manager assignment
SCRAPING_LOGIN_EMAIL=your-login-email@example.com
SCRAPING_LOGIN_PASSWORD=your-login-password
SCRAPING_COMPANY_NAME=your-company-name
SCRAPING_HEADLESS=false
SCRAPING_TIMEOUT=60000

# ------------------------------------------------------------------------------
# Batch Processing
# ------------------------------------------------------------------------------
BATCH_WORKERS=12
BATCH_LIMIT=0

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_INCLUDE_CORRELATION_ID=true
LOG_REDACT_PII=true

# Debug mode (enables verbose logging)
DEBUG=false

# ------------------------------------------------------------------------------
# Email Notifications (Optional)
# ------------------------------------------------------------------------------
NOTIFY_ENABLED=false
NOTIFY_PROVIDER=smtp
# NOTIFY_SMTP_HOST=smtp.example.com
# NOTIFY_SMTP_PORT=587
# NOTIFY_SMTP_USER=notifications@example.com
# NOTIFY_SMTP_PASSWORD=your-smtp-password
# NOTIFY_RECIPIENTS=ops@example.com,admin@example.com
# NOTIFY_SENDER_EMAIL=noreply@integration.local
# NOTIFY_SENDER_NAME=UKG Integration Suite

# ------------------------------------------------------------------------------
# Secrets Provider (Optional)
# ------------------------------------------------------------------------------
# Options: env (default), aws, vault
SECRETS_PROVIDER=env

# AWS Secrets Manager (if SECRETS_PROVIDER=aws)
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=matrix/ukg-bill/prod

# HashiCorp Vault (if SECRETS_PROVIDER=vault)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your-vault-token
# VAULT_PATH=secret/matrix/ukg-bill
