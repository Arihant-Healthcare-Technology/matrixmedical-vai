# ==============================================================================
# UKG to BILL.com Integration - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env files with real credentials to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# UKG Pro API Configuration
# ------------------------------------------------------------------------------
# Base URL for UKG Pro API
UKG_API_BASE=https://service4.ultipro.com

# UKG Pro credentials
UKG_USERNAME=your-ukg-username
UKG_PASSWORD=your-ukg-password

# UKG Customer API Key (required for API access)
UKG_API_KEY=your-ukg-customer-api-key

# Optional: Pre-encoded Basic Auth header (base64 of username:password)
# If set, used instead of UKG_USERNAME/UKG_PASSWORD
# UKG_BASIC_B64=

# ------------------------------------------------------------------------------
# BILL.com API Configuration
# ------------------------------------------------------------------------------
# API Base URL
# Production: https://gateway.bill.com/connect/v3
# Staging:    https://gateway.stage.bill.com/connect/v3
BILL_API_BASE=https://gateway.stage.bill.com/connect/v3

# BILL.com API Token (from BILL.com Developer Portal)
BILL_API_TOKEN=your-bill-api-token

# BILL.com Organization ID
BILL_ORG_ID=your-bill-org-id

# Optional: Default funding account for AP payments
# BILL_DEFAULT_FUNDING_ACCOUNT=your-funding-account-id

# ------------------------------------------------------------------------------
# BILL.com Browser Automation (for UI-only features)
# ------------------------------------------------------------------------------
# Required for CSV import and manager assignment
BILL_LOGIN_EMAIL=your-login-email@example.com
BILL_LOGIN_PASSWORD=your-login-password
BILL_COMPANY_NAME=your-company-name

# Optional: Browser automation URL
# BILL_UI_BASE_URL=https://app.bill.com

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
# Maximum API calls per minute (BILL.com limit is 60)
RATE_LIMIT_CALLS_PER_MINUTE=60

# ------------------------------------------------------------------------------
# Retry Configuration
# ------------------------------------------------------------------------------
# Maximum retry attempts for failed API calls
MAX_RETRIES=3

# Request timeout in seconds
REQUEST_TIMEOUT=30

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Log file path
# LOG_FILE=/var/log/ukg-bill/integration.log

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# Debug mode (enables verbose logging)
DEBUG=0

# Default UKG company ID (if not specified in CLI)
# UKG_COMPANY_ID=J9A6Y

# Default BILL.com user role for new users
# DEFAULT_BILL_ROLE=MEMBER

# Batch processing workers
# BATCH_WORKERS=12

# ------------------------------------------------------------------------------
# Email Notifications (Optional)
# ------------------------------------------------------------------------------
# SMTP server settings for error alerts
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASSWORD=your-smtp-password
# ALERT_RECIPIENTS=ops@example.com,admin@example.com

# ------------------------------------------------------------------------------
# Secrets Provider (Optional)
# ------------------------------------------------------------------------------
# Options: env (default), aws, vault
# SECRETS_PROVIDER=env

# AWS Secrets Manager (if SECRETS_PROVIDER=aws)
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=matrix/ukg-bill/prod

# HashiCorp Vault (if SECRETS_PROVIDER=vault)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your-vault-token
# VAULT_PATH=secret/matrix/ukg-bill

# ------------------------------------------------------------------------------
# Development Settings
# ------------------------------------------------------------------------------
# Skip SSL verification (development only, never in production)
# SKIP_SSL_VERIFY=0

# Mock API responses (for testing)
# MOCK_API_RESPONSES=0
