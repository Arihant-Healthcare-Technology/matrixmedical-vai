# ==============================================================================
# UKG to BILL.com Integration - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env files with real credentials to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# UKG Pro API Configuration
# ------------------------------------------------------------------------------
# Base URL for UKG Pro API
UKG_API_BASE=https://service4.ultipro.com

# UKG Pro credentials
UKG_USERNAME=motus
UKG_PASSWORD=**a3iZZyNv[iBV[D)0crA4SIq!zposF[Vjpev[n^s_v/Ua3P0#WYgp8ywne+{tMn

# UKG Customer API Key (required for API access)
UKG_CUSTOMER_API_KEY=QXML5

# Optional: Pre-encoded Basic Auth header (base64 of username:password)
# If set, used instead of UKG_USERNAME/UKG_PASSWORD
# UKG_BASIC_B64=

# Default UKG company ID
UKG_COMPANY_ID=J9A6Y

# Employee Change Filtering
# Only process employees changed within this many days (filters by dateTimeChanged)
UKG_DAYS_TO_PROCESS=2

# Job Code Filtering for BILL.com Sync
# Comma-separated list of qualified job codes (from primaryJobCode or jobCode field)
# Only employees with these job codes will be synced to BILL.com
# Format: JOB_CODE_FILTER=1122,1103,4214,...
JOB_CODE_FILTER=1122,1103,4214,4053,4152,4222,4044,4184,4182,4084,2905,4217,4154,2628,2409,1052,4117,2962,1030,4221,4132,2375,2095,4196,2056,4139,4061,2162,2630,4158,4223,2748,2377,4160,4149,2328,4005,4198,2958,1029,4038,4216,4183,4035,2262,2314,1051,4140,4090,2695,1134,4118,2698,4146,1119,2809,4046,2175,4003,4130,2703,1093,4135,2696,2626,1168,4052,4235,1102,2961,2564,4148,1163,2721,4186,2261,2506,1081,4080,4189,2036,2631,4115,1053,3024,1124,2792,1106,2240,4067,2847,2907,1131,4129,4047,3045,1041,1033,889,4197,2001,4100,4101,2423,2771,4188,2979,4229,4144,4064,2711,4089,4094,4095,4207,4105,4110,4107,4230,4018,4119,4077,4178,4125,2718,2373,4126,4206,4239,4167,4241,4142,4175,1070,4176,4173,4156,2793,4138,4180,4191,3036,4193,2012,4120,4022,2510,4194

