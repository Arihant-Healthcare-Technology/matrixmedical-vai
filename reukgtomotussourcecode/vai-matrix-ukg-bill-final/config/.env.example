# UKG to BILL.com Integration Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Environment
# =============================================================================
DEBUG=0
ENVIRONMENT=development

# =============================================================================
# UKG Pro API Configuration
# =============================================================================
UKG_BASE_URL=https://service4.ultipro.com
UKG_USERNAME=
UKG_PASSWORD=
UKG_CUSTOMER_API_KEY=
UKG_BASIC_B64=  # Optional: pre-encoded Basic auth token
UKG_COMPANY_ID=

# =============================================================================
# BILL.com API Configuration
# =============================================================================
# Shared token for both S&E and AP
BILL_API_TOKEN=

# Spend & Expense API
BILL_API_BASE=https://gateway.stage.bill.com/connect/v3/spend
# For production: https://gateway.bill.com/connect/v3/spend

# Accounts Payable API
BILL_AP_API_BASE=https://gateway.stage.bill.com/connect/v3
# For production: https://gateway.bill.com/connect/v3

# BILL defaults
BILL_DEFAULT_ROLE=MEMBER
BILL_PRODUCTION=false

# =============================================================================
# Batch Processing
# =============================================================================
BATCH_WORKERS=12
BATCH_LIMIT=0  # 0 = no limit

# =============================================================================
# Scraping (Browser Automation)
# =============================================================================
SCRAPING_HEADLESS=false
SCRAPING_TIMEOUT=60000
SCRAPING_LOGIN_EMAIL=
SCRAPING_LOGIN_PASSWORD=
SCRAPING_COMPANY_NAME=
SCRAPING_OUTPUT_DIR=output

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text
LOG_INCLUDE_CORRELATION_ID=true
LOG_REDACT_PII=true

# =============================================================================
# Notifications
# =============================================================================
NOTIFY_ENABLED=false
NOTIFY_PROVIDER=smtp  # smtp, ses, or sendgrid

# SMTP Settings
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=

# AWS SES Settings
NOTIFY_SES_REGION=us-east-1

# Recipients
NOTIFY_RECIPIENTS=  # Comma-separated email addresses
NOTIFY_SENDER_EMAIL=noreply@integration.local
NOTIFY_SENDER_NAME=UKG Integration Suite
