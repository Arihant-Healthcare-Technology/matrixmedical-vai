#!/bin/bash
# =============================================================================
# Azure Production Environment Configuration
# =============================================================================
# Copy this file to env.prod.sh and fill in the values
# =============================================================================

# Azure Resource Configuration
export AZURE_RESOURCE_GROUP="vai-integration-prod-rg"
export AZURE_LOCATION="eastus"
export AZURE_ACR_NAME="vaiacrprod"
export AZURE_CONTAINER_NAME="ukg-travelperk-sync-prod"
export AZURE_STORAGE_ACCOUNT="vaistorageprod"
export AZURE_FILE_SHARE="vai-travelperk-data"

# Image Configuration
export IMAGE_TAG="latest"

# UKG Configuration
export UKG_BASE_URL="https://service4.ultipro.com"
export UKG_CUSTOMER_API_KEY="your-ukg-api-key"
export UKG_USERNAME="your-ukg-username"
export UKG_PASSWORD="your-ukg-password"
# Optional: Pre-encoded base64 of "username:password"
# export UKG_BASIC_B64=""

# TravelPerk Configuration
export TRAVELPERK_API_BASE="https://app.travelperk.com"
export TRAVELPERK_API_KEY="your-travelperk-api-key"

# Batch Configuration
export COMPANY_ID="J9A6Y"
export STATES=""                    # Empty for all, or comma-separated: "FL,MS,NJ"
export EMPLOYEE_TYPE_CODES=""       # Empty for all, or comma-separated: "FTC,HRC"
export WORKERS="12"
export LOG_LEVEL="INFO"

# Optional: For testing
# export DRY_RUN="1"
# export LIMIT="10"
