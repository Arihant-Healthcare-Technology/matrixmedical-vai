# =============================================================================
# Development Environment - TravelPerk Integration
# =============================================================================
# This file contains development/sandbox configuration.
# Copy to .env for local development or specify via --env-file flag.
# =============================================================================

ENVIRONMENT=development

# -----------------------------------------------------------------------------
# UKG Pro Configuration (Development/Sandbox)
# -----------------------------------------------------------------------------
UKG_BASE_URL=https://service4.ultipro.com
UKG_USERNAME=
UKG_PASSWORD=
UKG_CUSTOMER_API_KEY=
UKG_BASIC_B64=
UKG_TIMEOUT=45

# -----------------------------------------------------------------------------
# TravelPerk Configuration (Sandbox)
# -----------------------------------------------------------------------------
TRAVELPERK_API_BASE=https://app.sandbox-travelperk.com
TRAVELPERK_API_KEY=
TRAVELPERK_TIMEOUT=60

# -----------------------------------------------------------------------------
# Batch Processing (Development - Limited)
# -----------------------------------------------------------------------------
COMPANY_ID=
WORKERS=4
MAX_RETRIES=2
RATE_LIMIT_CALLS_PER_MINUTE=100
LIMIT=10
DRY_RUN=true
SAVE_LOCAL=true
OUT_DIR=data/batch

# -----------------------------------------------------------------------------
# Filtering (Optional)
# -----------------------------------------------------------------------------
STATES=
EMPLOYEE_TYPE_CODES=

# -----------------------------------------------------------------------------
# Logging (Development - Verbose)
# -----------------------------------------------------------------------------
DEBUG=true
REDACT_PII=false

# -----------------------------------------------------------------------------
# Notifications (Disabled in Development)
# -----------------------------------------------------------------------------
NOTIFICATION_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_FROM=noreply@integration.local
NOTIFICATION_TO=

# -----------------------------------------------------------------------------
# Secrets Provider (Development - Use Environment Variables)
# -----------------------------------------------------------------------------
SECRETS_PROVIDER=env
