# =============================================================================
# Production Environment - TravelPerk Integration
# =============================================================================
# This file contains production configuration.
# Credentials should be injected via secrets manager or CI/CD pipeline.
# DO NOT commit actual secrets to version control.
# =============================================================================

ENVIRONMENT=production

# -----------------------------------------------------------------------------
# UKG Pro Configuration (Production)
# -----------------------------------------------------------------------------
UKG_BASE_URL=https://service4.ultipro.com
UKG_USERNAME=${UKG_USERNAME}
UKG_PASSWORD=${UKG_PASSWORD}
UKG_CUSTOMER_API_KEY=${UKG_CUSTOMER_API_KEY}
UKG_BASIC_B64=${UKG_BASIC_B64}
UKG_TIMEOUT=60

# -----------------------------------------------------------------------------
# TravelPerk Configuration (Production)
# -----------------------------------------------------------------------------
TRAVELPERK_API_BASE=https://app.travelperk.com
TRAVELPERK_API_KEY=${TRAVELPERK_API_KEY}
TRAVELPERK_TIMEOUT=90

# -----------------------------------------------------------------------------
# Batch Processing (Production - Full Capacity)
# -----------------------------------------------------------------------------
COMPANY_ID=${COMPANY_ID}
WORKERS=12
MAX_RETRIES=3
RATE_LIMIT_CALLS_PER_MINUTE=100
LIMIT=0
DRY_RUN=false
SAVE_LOCAL=false
OUT_DIR=data/batch

# -----------------------------------------------------------------------------
# Filtering (Optional - Set via CI/CD if needed)
# -----------------------------------------------------------------------------
STATES=${STATES}
EMPLOYEE_TYPE_CODES=${EMPLOYEE_TYPE_CODES}

# -----------------------------------------------------------------------------
# Logging (Production - Structured)
# -----------------------------------------------------------------------------
DEBUG=false
REDACT_PII=true

# -----------------------------------------------------------------------------
# Notifications (Production - Enabled)
# -----------------------------------------------------------------------------
NOTIFICATION_ENABLED=true
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=587
SMTP_USERNAME=${SMTP_USERNAME}
SMTP_PASSWORD=${SMTP_PASSWORD}
NOTIFICATION_FROM=${NOTIFICATION_FROM}
NOTIFICATION_TO=${NOTIFICATION_TO}

# -----------------------------------------------------------------------------
# Secrets Provider (Production - AWS Secrets Manager)
# -----------------------------------------------------------------------------
SECRETS_PROVIDER=aws
AWS_REGION=us-east-1
AWS_SECRET_NAME=matrix/ukg-travelperk/prod
