# UKG Pro to TravelPerk Integration - Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# UKG Pro API Configuration
# ============================================
UKG_BASE_URL=https://service4.ultipro.com
UKG_USERNAME=motus
UKG_PASSWORD=**a3iZZyNv[iBV[D)0crA4SIq!zposF[Vjpev[n^s_v/Ua3P0#WYgp8ywne+{tMn
# Optional: Pre-encoded base64 of "username:password" (overrides USERNAME/PASSWORD)
# UKG_BASIC_B64=
UKG_CUSTOMER_API_KEY=QXML5

# Company ID for UKG queries
COMPANY_ID=J9A6Y

# ============================================
# TravelPerk SCIM API Configuration
# ============================================
# Sandbox environment
TRAVELPERK_API_BASE=https://app.sandbox-travelperk.com

# Production environment (uncomment for production)
# TRAVELPERK_API_BASE=https://app.travelperk.com

# API Key for authentication
TRAVELPERK_API_KEY=9vNTGT.O3MF423I70wB7OMFhRpH7XjUQnDz6Ver

# ============================================
# Batch Processing Configuration
# ============================================
# Number of parallel workers
WORKERS=6

# Rate limiting (calls per minute)
# RATE_LIMIT_CALLS_PER_MINUTE=60

# Maximum retry attempts
MAX_RETRIES=2

# Filter by US states (comma-separated, e.g., FL,MS,NJ)
# STATES=

# Filter by employee type codes (comma-separated, e.g., FTC,HRC,TMC)
# EMPLOYEE_TYPE_CODES=

# Output directory for batch files
# OUT_DIR=data/batch

# Limit number of users to process (for testing)
# LIMIT=10

# ============================================
# Notifications (Optional)
# ============================================
# Email notifications for batch completion
# NOTIFICATION_ENABLED=0
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=alerts@example.com
# SMTP_PASSWORD=your-smtp-password
# NOTIFICATION_FROM=alerts@matrixmedical.com
# NOTIFICATION_TO=admin@matrixmedical.com

# ============================================
# Secrets Provider (Optional)
# ============================================
# Options: env (default), aws, vault
# SECRETS_PROVIDER=env

# AWS Secrets Manager (if SECRETS_PROVIDER=aws)
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=matrix/ukg-travelperk/prod

# HashiCorp Vault (if SECRETS_PROVIDER=vault)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=your-vault-token
# VAULT_PATH=secret/matrix/ukg-travelperk

# ============================================
# Debug & Development
# ============================================
# Enable debug logging
DEBUG=0

# Redact PII in logs
REDACT_PII=1

# Dry-run mode (validate without API calls)
# DRY_RUN=0

# Save local JSON files
# SAVE_LOCAL=0
